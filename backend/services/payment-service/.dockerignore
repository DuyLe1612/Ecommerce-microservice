# Ignore build outputs — keep the image small and fast
target/
*.class
*.jar
*.log

# Ignore IDE files
.idea/
*.iml
.vscode/
*.swp

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore agent/transcript files
agent/
*.jsonl

# Ignore test sources
src/test/

# Ignore wrapper downloads cache
.mvn/wrapper/*.jar
